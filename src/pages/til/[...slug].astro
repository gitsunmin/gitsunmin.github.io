---
import MainLayout from '@/layouts/MainLayout.astro';
import { TILPage } from '@/components/pages/TIL';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { MDXReplacer } from '@/components/MDXReplacer';

export async function getStaticPaths() {
  const tilEntries = await getCollection('til');

  return tilEntries.map((entry: CollectionEntry<'til'>) => ({
    params: { slug: entry.id.replace(/\.mdx$/, '') },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'til'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title =
  entry.data.title ||
  entry.id
    .split('/')
    .pop()
    ?.replace(/\.mdx$/, '')
    ?.replace(/-/g, ' ') ||
  'TIL';

const category = entry.id.split('/')[0];
---

<MainLayout title={`${title} - TIL - Gitsunmin`} headerTitle="TIL">
  <TILPage title={title} category={category}>
    <article class="prose dark:prose-invert max-w-none">
      <Content components={MDXReplacer({})} />
    </article>
  </TILPage>
</MainLayout>
