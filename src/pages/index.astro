---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { cn } from '@/lib/utils';
import { ICON_MAP } from '@/lib/iconMap';
import type { IconName } from '@/lib/iconMap';
import { IPhoneFolder } from '@/components/IPhoneFolder';
import type { FolderLink } from '@/components/IPhoneFolder';

type LinkItem = {
  __type: 'INNER' | 'OUTER';
  id: string;
  label: string;
  status: 'ENABLED' | 'DISABLED';
  target: '_self' | '_blank';
  to: string;
  icon: IconName;
};

type FolderItem = {
  __type: 'FOLDER';
  id: string;
  label: string;
  status: 'ENABLED' | 'DISABLED';
  links: FolderLink[];
};

type Item = LinkItem | FolderItem;

const LINKS: Item[] = [
  {
    __type: 'INNER',
    id: 'careers',
    label: 'Careers',
    status: 'ENABLED',
    target: '_self',
    to: '/careers',
    icon: 'Building2',
  },
  {
    __type: 'INNER',
    id: 'works',
    label: 'Works',
    status: 'ENABLED',
    target: '_self',
    to: '/works',
    icon: 'Layers',
  },
  {
    __type: 'INNER',
    id: 'blog',
    label: 'Blog',
    status: 'ENABLED',
    target: '_self',
    to: '/blog',
    icon: 'Quote',
  },
  {
    __type: 'INNER',
    id: 'til',
    label: 'TIL',
    status: 'ENABLED',
    target: '_self',
    to: '/til/README',
    icon: 'FileText',
  },
  {
    __type: 'FOLDER',
    id: 'tools',
    label: 'Tools',
    status: 'ENABLED',
    links: [
      { id: 'loom',         label: 'Loom',         to: '/loom',         target: '_self', iconName: 'Blend'  },
      { id: 'rec-room',     label: 'Rec Room',     to: '/rec-room',     target: '_self', iconName: 'Mic'    },
      { id: 'frame-studio', label: 'Frame Studio', to: '/frame-studio', target: '_self', iconName: 'Frame'  },
      { id: 'qr-code',        label: 'QR Code',        to: '/qr-code',        target: '_self', iconName: 'QrCode' },
      // { id: 'interview-bot', label: 'Interview Bot', to: '/interview-bot', target: '_self', iconName: 'Bot'    },
    ],
  },
  {
    __type: 'INNER',
    id: 'interview',
    label: 'Interview',
    status: 'DISABLED',
    target: '_self',
    to: '/interview',
    icon: 'MessageSquareCode',
  },
  {
    __type: 'FOLDER',
    id: 'social',
    label: 'Social',
    status: 'ENABLED',
    links: [
      { id: 'github',   label: 'Github',   to: 'https://github.com/gitsunmin',            target: '_blank', iconName: 'GithubIcon'   },
      { id: 'linkedin', label: 'LinkedIn', to: 'https://www.linkedin.com/in/gitsunmin/', target: '_blank', iconName: 'LinkedinIcon' },
    ],
  },
  {
    __type: 'INNER',
    id: 'settings',
    label: 'Settings',
    status: 'ENABLED',
    target: '_self',
    to: '/settings',
    icon: 'Settings',
  },
];
---

<BaseLayout
  ogImage="/assets/default-og-omage.webp"
  jsonLd={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Gitsunmin',
    url: 'https://gitsunmin.github.io',
    description: "Gitsunmin's website | 김선민의 웹사이트",
    author: {
      '@type': 'Person',
      name: 'Sunmin Kim',
      url: 'https://gitsunmin.github.io',
      sameAs: [
        'https://github.com/gitsunmin',
        'https://www.linkedin.com/in/gitsunmin/',
      ],
    },
  })}
>
  <main
    class={cn(
      'fixed z-[1]',
      'mx-auto px-4 py-6 w-full h-dvh break-all pb-10',
      'bg-transparent'
    )}
  >
    <ul class="grid grid-cols-[repeat(auto-fit,minmax(64px,1fr))] gap-4">
      {
        LINKS.filter(item => item.status === 'ENABLED').map(item =>
          item.__type === 'FOLDER' ? (
            <li class="flex flex-col justify-center items-center">
              <IPhoneFolder client:load label={item.label} links={item.links} />
            </li>
          ) : (
            <li class="flex flex-col justify-center items-center">
              <a
                href={item.to}
                target={item.target}
                rel={item.target === '_blank' ? 'noopener noreferrer' : undefined}
                class={cn(
                  'flex w-14 flex-col justify-center items-center gap-x-1 gap-y-2 active:transform active:duration-300 active:scale-150 active:opacity-80 hover:opacity-90 relative group'
                )}
              >
                <div
                  class={cn(
                    'size-14 rounded-xl flex items-center justify-center',
                    'backdrop-blur-md backdrop-saturate-150',
                    'bg-white/30 dark:bg-white/10',
                    'border border-white/70 dark:border-white/20',
                    'shadow-[0_4px_24px_rgba(0,0,0,0.10),inset_0_1px_0_rgba(255,255,255,0.7),inset_0_-1px_0_rgba(0,0,0,0.05)]',
                    'dark:shadow-[0_4px_24px_rgba(0,0,0,0.35),inset_0_1px_0_rgba(255,255,255,0.15),inset_0_-1px_0_rgba(0,0,0,0.2)]',
                    'transition-all duration-300',
                    'group-hover:bg-white/40 dark:group-hover:bg-white/15',
                    'group-hover:shadow-[0_8px_32px_rgba(0,0,0,0.15),inset_0_1px_0_rgba(255,255,255,0.8)]',
                    'dark:group-hover:shadow-[0_8px_32px_rgba(0,0,0,0.45),inset_0_1px_0_rgba(255,255,255,0.2)]'
                  )}
                >
                  {(() => {
                    const Icon = ICON_MAP[item.icon];
                    return Icon ? <Icon size={28} className="text-foreground" /> : null;
                  })()}
                </div>
                <div
                  class={cn(
                    'text-xs text-foreground break-keep text-center line-clamp-1',
                    'transition-all duration-300 ease-out group-hover:opacity-0 group-hover:translate-y-1'
                  )}
                >
                  {item.label}
                </div>
                <div
                  class={cn(
                    'absolute bottom-0 left-1/2 -translate-x-1/2 whitespace-nowrap',
                    'text-xs text-foreground px-2.5 py-1.25 rounded-lg',
                    'backdrop-blur-md backdrop-saturate-150',
                    'bg-white/25 dark:bg-white/10',
                    'border border-white/60 dark:border-white/20',
                    'shadow-[0_2px_16px_rgba(0,0,0,0.10),inset_0_1px_0_rgba(255,255,255,0.5)]',
                    'dark:shadow-[0_2px_16px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.1)]',
                    'pointer-events-none z-10',
                    'opacity-0 -translate-y-1',
                    'group-hover:opacity-100 group-hover:translate-y-0',
                    'transition-all duration-300 ease-out'
                  )}
                >
                  {item.label}
                </div>
              </a>
            </li>
          )
        )
      }
    </ul>
  </main>
</BaseLayout>
