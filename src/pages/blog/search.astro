---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="블로그 검색" description="블로그 글 검색">
  <div class="max-w-3xl mx-auto px-4 py-18 md:py-24">
    <h1 class="text-4xl font-bold mb-8">블로그 검색</h1>
    <div id="pagefind-search"></div>
  </div>
</MainLayout>

<script is:inline>
  async function initPagefind() {
    const el = document.getElementById('pagefind-search');
    if (!el) return;

    // 이미 초기화된 경우 초기화 상태 제거 후 재실행 (view transition 대응)
    el.innerHTML = '';

    // CSS 동적 주입 (중복 방지)
    if (!document.querySelector('link[data-pagefind-css]')) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      link.dataset.pagefindCss = '';
      document.head.appendChild(link);
    }

    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      new PagefindUI({
        element: el,
        showSubResults: true,
        translations: {
          placeholder: '검색어를 입력하세요...',
          zero_results: '"[SEARCH_TERM]"에 대한 결과가 없습니다.',
        },
      });
    } catch {
      el.innerHTML = '<p style="color:gray;padding:1rem 0;">검색 기능은 빌드 후 사용 가능합니다.</p>';
    }
  }

  // 초기 진입 및 view transition 이후 모두 처리
  document.addEventListener('astro:page-load', initPagefind);
</script>
