---
import { type GetStaticPaths } from 'astro';
import { type CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MainLayout from '@/layouts/MainLayout.astro';
import { MDXReplacer } from '@/components/MDXReplacer';
import TableOfContents from '@/components/TableOfContents.astro';

export const getStaticPaths = (async () => {
  const posts: CollectionEntry<'blog'>[] = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: post,
  }));
}) satisfies GetStaticPaths;

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await post.render();
const DEFAULT_HERO_IMAGE = '/assets/blog/default-thumbnail.svg';
const heroImage = post.data.heroImage || DEFAULT_HERO_IMAGE;

---
<MainLayout title={post.data.title} description={post.data.description}>
  <div class="max-w-6xl mx-auto px-4 py-18 md:px-8 md:py-24">
    <!-- Mobile TOC -->
    <div class="lg:hidden mb-6">
      <TableOfContents headings={headings} />
    </div>

    <div class="flex gap-10 items-start">
      <article class="prose dark:prose-invert prose-lg min-w-0 flex-1">
        <img src={heroImage} onerror={`this.src='${DEFAULT_HERO_IMAGE}';`} alt={post.data.title} class="w-full h-auto rounded-lg mb-8 shadow-lg" />
        <h1 class="text-3xl md:text-4xl font-extrabold mb-4">{post.data.title}</h1>
        <div class="text-sm md:text-base text-gray-500 dark:text-gray-400 mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
          <span>작성일: {post.data.pubDate.toLocaleDateString('ko-KR')}</span>
          {post.data.updatedDate && <span class="ml-2">(수정일: {post.data.updatedDate.toLocaleDateString('ko-KR')})</span>}
          <div class="mt-3 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => <span class="inline-block bg-gray-200 dark:bg-gray-700 rounded-full px-3 py-1 text-sm font-semibold text-gray-700 dark:text-gray-200"># {tag}</span>)}
          </div>
        </div>
        <Content components={MDXReplacer({})} />
        <section class="pb-16 pt-8">
          <script is:inline src="https://giscus.app/client.js"
            data-repo="gitsunmin/gitsunmin.github.io"
            data-repo-id="R_kgDOMZl2kA"
            data-category="Comments"
            data-category-id="DIC_kwDOMZl2kM4C3wBs"
            data-mapping="pathname"
            data-strict="1"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="top"
            data-theme="preferred_color_scheme"
            data-lang="ko"
            data-loading="lazy"
            crossorigin="anonymous"
            async>
          </script>
        </section>
      </article>

      <!-- Desktop TOC sidebar -->
      <aside class="hidden lg:block w-56 xl:w-64 shrink-0 sticky top-24 self-start">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>


  <script is:inline>
    function initCopyButtons() {
      const wrappers = document.querySelectorAll('.code-block-wrapper');
      
      wrappers.forEach((wrapper) => {
        const button = wrapper.querySelector('.copy-button');
        const pre = wrapper.querySelector('pre');
        const copyIcon = button?.querySelector('.copy-icon');
        const checkIcon = button?.querySelector('.check-icon');
        
        if (!button || !pre) return;
        
        // Remove existing listener if any (by cloning)
        const newButton = button.cloneNode(true);
        button.parentNode?.replaceChild(newButton, button);
        
        newButton.addEventListener('click', async () => {
          const codeElement = pre.querySelector('code');
          const code = codeElement?.innerText || pre.innerText || '';
          
          try {
            await navigator.clipboard.writeText(code);
            
            const btnCopyIcon = newButton.querySelector('.copy-icon');
            const btnCheckIcon = newButton.querySelector('.check-icon');
            
            // Show check icon
            btnCopyIcon?.classList.add('hidden');
            btnCheckIcon?.classList.remove('hidden');
            newButton.classList.add('opacity-100');
            newButton.classList.remove('opacity-0');
            
            // Reset after 2 seconds
            setTimeout(() => {
              btnCopyIcon?.classList.remove('hidden');
              btnCheckIcon?.classList.add('hidden');
              newButton.classList.remove('opacity-100');
              newButton.classList.add('opacity-0', 'group-hover:opacity-100');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy code:', err);
          }
        });
      });
    }

    // Initialize
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCopyButtons);
    } else {
      initCopyButtons();
    }

    // Re-initialize on view transitions
    document.addEventListener('astro:page-load', initCopyButtons);
  </script>

  <style is:global>
    .giscus,
    .giscus-frame {
      width: 100% !important;
    }

    .code-block-wrapper:hover .copy-button {
      opacity: 1 !important;
    }
    
    .code-block-wrapper pre {
      transition: border-color 0.2s ease;
    }
    
    .code-block-wrapper:hover pre {
      border-color: rgb(156 163 175 / 0.5) !important;
    }
    
    .dark .code-block-wrapper:hover pre {
      border-color: rgb(75 85 99 / 0.5) !important;
    }
  </style>
</MainLayout>
