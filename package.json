{
  "name": "gitsunmin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "biome format --write .",
    "deploy": "gh-pages -d dist --dotfiles",
    "bd": "bun run build && bun run deploy",
    "pull:modules": "git submodule update --remote --merge",
    "gen:book-cover": "bun .scripts/generate-book-cover.ts",
    "test:vi": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
