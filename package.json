{
  "name": "gitsunmin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "bun .scripts/optimize-blog-images.ts && astro check && astro build",
    "preview": "astro preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
