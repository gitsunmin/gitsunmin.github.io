    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/snapshot": "^4.0.18",
    "@vitest/ui": "^4.0.18",
